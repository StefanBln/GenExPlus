# Example report job — works after `mvn package` with no database.
# Documentation: docs/HOWTO.md · Property reference: docs/CONFIGURATION.md

report.database.optional=true
report.template=sample-report.jrxml
report.output.dir=genexplus-output
report.output.filename=sample-report.pdf
report.format=PDF
report.parameter.ReportTitle=Hello from GenExPlus
report.parameter.Author=Quick Start
report.timestamp.auto=false
verbose=false

# Optional email delivery (requires mail.smtp.enabled=true in application.properties)
report.email.enabled=false
report.email.to=recipient@example.com
report.email.subject=GenExPlus Sample Report
report.email.body=<p>Please find the report attached.</p>
report.email.body.plain=Please find the report attached.
